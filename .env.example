# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase dashboard → Project Settings → Database → Connection string (Session mode, port 5432)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production frontend URL (your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# ── Frontend (VITE_ prefix exposes to the browser bundle) ────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Leave empty in production — Vite proxy and same-domain Vercel routing handle this
VITE_API_URL=
